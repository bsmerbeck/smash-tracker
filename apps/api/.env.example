# Node environment. Defaults to "development".
NODE_ENV=development

# Port/host the Fastify server listens on. Defaults shown.
# On Cloud Run, the platform injects PORT at runtime — do not hardcode it in
# production; the default/fallback here is only for local development.
PORT=3001
HOST=0.0.0.0

# Realtime Database instance URL. Always required — used both for real
# Firebase projects and when pointing at the RTDB emulator.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# --- Credentials (choose ONE of the following for real usage) ---

# Path to a service account JSON key file. Picked up automatically by
# firebase-admin's applicationDefault() credential. Useful for local
# development against a real Firebase project. Not needed when using the
# RTDB emulator, and not needed on Cloud Run — there, applicationDefault()
# automatically uses the Cloud Run service's runtime service account via the
# metadata server, so leave this unset in production.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Local development / emulator ---

# When set, firebase-admin connects to the local Realtime Database emulator
# instead of production, and no real credentials are required. Typical value
# when running `firebase emulators:start`: 127.0.0.1:9000
FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000

# --- CORS ---

# Comma-separated list of origins allowed to call this API. Defaults to the
# Vite dev server origin. Production traffic to the deployed API is
# same-origin (via the Firebase Hosting rewrite of /api/** to Cloud Run), so
# this mainly matters for local dev; the Firebase Hosting domains are listed
# here as a belt-and-braces fallback in case the API is ever called directly.
CORS_ORIGIN=http://localhost:5173,https://smash-tracker-f97b7.web.app,https://smash-tracker-f97b7.firebaseapp.com

# --- start.gg integration (optional) ---
# All five STARTGG_* values must be set for the integration routes to work;
# when any is missing, /api/integrations/startgg/* and /api/auth/startgg/*
# answer 503 and the rest of the API works normally.

# OAuth app credentials from
# https://start.gg/admin/profile/developer/applications — the redirect URI
# below must be registered on the app EXACTLY (add both the production and
# local values as separate entries there).
STARTGG_CLIENT_ID=your-startgg-client-id
STARTGG_CLIENT_SECRET=your-startgg-client-secret
STARTGG_REDIRECT_URI=http://localhost:3001/api/integrations/startgg/callback

# Server-side start.gg API token (personal or app token) used to fetch
# public tournament set data during syncs. This is NOT a user token — set
# data on start.gg is public and queried by player id.
STARTGG_API_TOKEN=your-startgg-api-token

# Any long random string; HMAC-signs the OAuth state parameter.
# e.g. `openssl rand -hex 32`
STARTGG_STATE_SECRET=any-long-random-string

# SPA origin that OAuth callbacks redirect back to.
WEB_BASE_URL=http://localhost:5173

# --- V8-A: parry.gg integration (optional) ---
# A single API key enables /api/integrations/parrygg/*; when absent, those
# routes answer 503 and the rest of the API works normally. Unlike start.gg,
# parry.gg has no OAuth app to register — this is a bare API key sent as the
# X-API-KEY gRPC-Web call metadata header on every request.
PARRYGG_API_KEY=your-parrygg-api-key

# --- V7-B: AI scouting reports (optional) ---
# Both values must be set for /api/reports to work; when either is missing,
# every /api/reports* route answers 503 and the rest of the API works
# normally (including /api/scout, which the reports feature is layered on).

# Claude API key used to generate scouting reports.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Comma-separated list of Firebase uids allowed to generate AI reports. This
# is a paid, per-token feature, so it's opt-in per uid even once a key is set.
REPORTS_ALLOWED_UIDS=uid1,uid2

# --- V7-C: Stripe-powered credit packs (optional) ---
# Both values must be set for /api/billing to work; when either is missing,
# every /api/billing* route answers 503 AND non-allowlisted uids get exactly
# the pre-V7-C 403 on report generation (no behavior change). Uids in
# REPORTS_ALLOWED_UIDS above always stay free/unlimited regardless of these
# vars — this paywall exists only to cover the cost of everyone else's usage.
# Credit pack prices/credit counts live in packages/shared/src/billing.ts
# (CREDIT_PACKS) — edit that one constant to change pricing.

# Stripe secret key used to create Checkout Sessions (sk_test_... in test
# mode, sk_live_... in production). From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Signing secret for the POST /api/billing/webhook endpoint, from the
# webhook's settings in the Stripe dashboard
# (https://dashboard.stripe.com/webhooks). Register the webhook at
# https://<your-cloud-run-service>/api/billing/webhook, subscribed to at
# least the `checkout.session.completed` event.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
